# ============================================================
# Pooh Dev Gold Analytics — Feeder Script Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ============================================================

# Tiingo API Key — ลงทะเบียนฟรีที่ https://tiingo.com
TIINGO_API_KEY=your_tiingo_api_key_here

# Supabase — ดูได้ที่ Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Premium คือค่าบวกเพิ่มในการคำนวณราคาทอง (บาท) — ปกติ 0
GOLD_PREMIUM=0

# ช่วงเวลาในการดึงข้อมูล (มิลลิวินาที) — 15000 = 15 วินาที
FETCH_INTERVAL_MS=15000
